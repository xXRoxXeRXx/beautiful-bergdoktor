# ==============================================
# Der BergdoktorBot  Konfiguration
# Kopiere diese Datei als .env und passe die Werte an.
# ==============================================
#
# Alle weiteren Einstellungen (Telegram, Aerzte, Check-Intervall etc.)
# werden ueber das Web-Interface unter http://localhost:WEB_PORT verwaltet
# und in der SQLite-Datenbank gespeichert.

# Web-Interface (Zugangsdaten fuer das Dashboard)
# REQUIRED – the app will refuse to start if these are left empty.
WEB_USER=changeme
WEB_PASS=changeme_with_a_strong_password
WEB_PORT=8080

# Flask session secret – generate once with: python -c "import secrets; print(secrets.token_hex(32))"
# REQUIRED for persistent sessions across restarts. Keep this value secret.
FLASK_SECRET_KEY=replace_with_a_random_64_hex_character_string

